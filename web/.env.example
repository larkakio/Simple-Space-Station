# Public URL (Vercel production). For local dev you can use http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://simple-space-station.vercel.app

# Base mainnet (8453) — default for production check-in
NEXT_PUBLIC_CHAIN_ID=8453

# After `forge create` / deploy — CheckIn.sol
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=

# Base.dev project (Settings) — meta tag + attribution
# Base.dev → App settings → App ID (meta base:app_id)
NEXT_PUBLIC_BASE_APP_ID=69df3e6e6d8c62b41bf7a38d
NEXT_PUBLIC_BUILDER_CODE=

# Rare: raw ERC-8021 hex suffix instead of bc_ code via ox
# NEXT_PUBLIC_BUILDER_CODE_SUFFIX=0x

# Optional WalletConnect (wagmi)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
